# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/
.bun/

# ─────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────
coverage/
.nyc_output/

# ─────────────────────────────────────────────
# Next.js
# ─────────────────────────────────────────────
.next/
out/
.next-static/
.next/cache/

# ─────────────────────────────────────────────
# Production builds
# ─────────────────────────────────────────────
build/
dist/

# ─────────────────────────────────────────────
# Environment files
# (commit only if intentionally required)
# ─────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────
# Debug / Logs
# ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*
*.log

# ─────────────────────────────────────────────
# OS-specific junk
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
Desktop.ini

# ─────────────────────────────────────────────
# Editor folders
# ─────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp

# ─────────────────────────────────────────────
# TypeScript
# ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────
*.pem
*.key
*.crt
*.pid
*.seed
*.orig
*.rej

# ─────────────────────────────────────────────
# Turbo / SWC / Build tools
# ─────────────────────────────────────────────
.turbo/
.swc/
.eslintcache
.stylelintcache
